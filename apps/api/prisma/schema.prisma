// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - core entity
model User {
  id            String   @id @default(cuid())
  phone         String   @unique
  name          String
  avatarUrl     String?
  role          String   @default("player") // 'player', 'host', 'admin'
  city          String?
  district      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  hostProfile   HostProfile?
  hostedSessions GameSession[]
  participations SessionParticipant[]

  @@index([phone])
  @@index([role])
}

// HostProfile model - one-to-one with User
model HostProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  displayName   String
  bio           String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isActive])
}

// Venue model - physical location where sessions happen
model Venue {
  id            String   @id @default(cuid())
  name          String
  city          String
  district      String
  address       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  sessions      GameSession[]

  @@index([city])
  @@index([district])
  @@index([city, district])
}

// GameSession model - badminton session
model GameSession {
  id            String   @id @default(cuid())
  hostId        String
  venueId       String
  title         String
  description   String?
  date          String   // ISO date: YYYY-MM-DD
  startTime     String   // HH:mm format
  endTime       String   // HH:mm format
  skillLevel    String   // 'beginner', 'intermediate', 'advanced'
  maxPlayers    Int      @default(16)
  priceLabel    String?  // display only for MVP
  status        String   @default("open") // 'open', 'full', 'completed', 'cancelled'
  sportType     String   @default("badminton")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  host          User     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  venue         Venue    @relation(fields: [venueId], references: [id])
  participants  SessionParticipant[]

  @@index([hostId])
  @@index([venueId])
  @@index([date])
  @@index([status])
  @@index([skillLevel])
}

// SessionParticipant model - join relationship
model SessionParticipant {
  id                String   @id @default(cuid())
  sessionId         String
  userId            String
  attendanceStatus  String   @default("joined") // 'joined', 'confirmed', 'declined', 'removed'
  joinedAt          DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  session           GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}
