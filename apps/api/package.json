{
  "name": "@sport-match/api",
  "version": "0.1.0",
  "description": "Sport Match API - NestJS backend",
  "author": "Sport Match Team",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "db:setup": "drizzle-kit generate && drizzle-kit migrate",
    "db:migrate": "drizzle-kit generate && drizzle-kit migrate",
    "db:migrate:deploy": "drizzle-kit migrate",
    "db:seed": "ts-node drizzle/seed.ts",
    "db:reset": "drizzle-kit drop && npm run db:setup && npm run db:seed"
  },
  "dependencies": {
    "@nestjs/common": "^10.2.10",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.10",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.2.10",
    "@nestjs/swagger": "^11.4.1",
    "@sport-match/shared": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@sport-match/eslint-config": "workspace:*",
    "@sport-match/typescript-config": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}
